rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============ HELPER FUNCTIONS ============
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // NEW: Check if the user document has role 'admin'
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function hasRequiredFields(requiredFields) {
      return request.resource.data.keys().hasAll(requiredFields);
    }

    function isChatParticipant(chatId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/chats/$(chatId)).data.participants is list &&
        get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
    }

    function isCallParticipant(chatId, callId) {
      return isChatParticipant(chatId) &&
        get(/databases/$(database)/documents/chats/$(chatId)/calls/$(callId)).data.callerId is string &&
        get(/databases/$(database)/documents/chats/$(chatId)/calls/$(callId)).data.calleeId is string &&
        (
          request.auth.uid == get(/databases/$(database)/documents/chats/$(chatId)/calls/$(callId)).data.callerId ||
          request.auth.uid == get(/databases/$(database)/documents/chats/$(chatId)/calls/$(callId)).data.calleeId
        );
    }

    // ============ USERS ============
    match /users/{userId} {
      allow read: if isSignedIn();

      // Updated: Allow Admin to update for banning/roles
      allow create: if isOwner(userId) &&
        hasRequiredFields(['id', 'displayName', 'email']) &&
        request.resource.data.id == userId;
        
      allow update: if (isOwner(userId) &&
        hasRequiredFields(['id', 'displayName', 'email']) &&
        request.resource.data.id == userId) || isAdmin();

      allow delete: if isAdmin();

      match /fcmTokens/{token} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      match /presence/{presenceDoc} {
        allow read, write: if isOwner(userId);
      }

      match /drafts/{draftDoc} {
        allow read, write: if isOwner(userId);
      }
      
      match /followers/{followerId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.userId == followerId &&
          request.resource.data.createdAt is number;
        allow delete: if isSignedIn() &&
          (request.auth.uid == resource.data.userId || isOwner(userId) || isAdmin());
      }

      match /following/{followingId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() &&
          request.auth.uid == userId &&
          request.resource.data.userId == followingId &&
          request.resource.data.createdAt is number;
        allow delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }

      match /friendRequests/{requestId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isSignedIn() &&
          request.resource.data.fromUserId == request.auth.uid &&
          request.resource.data.toUserId == userId &&
          hasRequiredFields(['fromUserId','toUserId','createdAt']);
        allow delete: if isOwner(userId) || resource.data.fromUserId == request.auth.uid || isAdmin();
      }

      match /outgoingFriendRequests/{requestId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /notifications/{notificationId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isSignedIn() &&
          request.resource.data.actorUserId == request.auth.uid &&
          request.resource.data.toUserId == userId &&
          hasRequiredFields(['actorUserId','toUserId','type','createdAt']);
        allow update, delete: if isOwner(userId) || isAdmin();
      }

      match /blocks/{blockedUserId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, write: if (isOwner(userId) &&
          hasRequiredFields(['blockedAt']) &&
          request.resource.data.blockedAt is number) || isAdmin();
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /activities/{activityId} {
        allow read: if isSignedIn();
        allow create: if isOwner(userId) &&
          hasRequiredFields(['type', 'text', 'createdAt']);
        allow update, delete: if isOwner(userId) || isAdmin();
      }

      match /incomingCalls/{callId} {
        allow read: if isOwner(userId);
        allow create: if isSignedIn() &&
          request.resource.data.callerId is string &&
          request.resource.data.callerId == request.auth.uid &&
          request.resource.data.calleeId is string &&
          request.resource.data.calleeId == userId &&
          request.resource.data.chatId is string &&
          request.resource.data.callId is string &&
          request.resource.data.startedAt is number &&
          request.resource.data.updatedAt is number &&
          request.resource.data.status is string &&
          request.resource.data.status == 'RINGING' &&
          request.resource.data.chatId is string &&
          request.resource.data.callType is string &&
          request.resource.data.callType in ['voice', 'video'];
        allow update: if isOwner(userId) || (
          isSignedIn() && request.auth.uid == resource.data.callerId
        );
        allow delete: if isOwner(userId) || (
          isSignedIn() && request.auth.uid == resource.data.callerId
        ) || isAdmin();
      }
    }

    // ============ GLOBAL REPORTS ============
    // NEW: Needed for Admin Moderation feature
    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    // ============ CHATS ============
    match /chats/{chatId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() &&
        hasRequiredFields(['participants', 'lastMessage', 'lastMessageTime']) &&
        request.resource.data.participants is list &&
        request.resource.data.participants.size() == 2 &&
        request.auth.uid in request.resource.data.participants;

      allow update: if isSignedIn() && (resource.data.participants.hasAny([request.auth.uid]) || isAdmin()) && (
        request.resource.data.participants == resource.data.participants
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'lastMessage','lastMessageSenderName','lastMessageSenderId','lastMessageTime',
          'lastMessageType','lastCallType','lastCallStatus',
          'timestamp','typingUserIds','typingUpdatedAt','unreadCount','unreadCounts','isPinned','pinnedAt',
          'isMuted','isArchived'
        ])
      );

      allow delete: if isAdmin();

      // -------- MESSAGES --------
      match /messages/{messageId} {
        allow read: if isChatParticipant(chatId) || isAdmin();

        allow create: if isChatParticipant(chatId) &&
          request.resource.data.senderId is string &&
          request.resource.data.senderId == request.auth.uid;

        allow update: if (isChatParticipant(chatId) || isAdmin()) && (
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'seen', 'status'])
          )
          ||
          (
            resource.data.messageType == 'call_invite' &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'callStatus', 'acceptedAt', 'declinedAt', 'missedAt', 'endedAt', 'updatedAt', 'expiresAt'
            ])
          )
          ||
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deletedForUsers', 'updatedAt'])
          )
          ||
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'hiddenTextFor', 'updatedAt'])
          )
          ||
          (
            resource.data.senderId == request.auth.uid &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'content', 'text', 'isEncrypted',
              'encryptedPayload', 'iv',
              'encryptedKeyForSender', 'encryptedKeyForRecipient',
              'encryptedKeyForSenderSha1', 'encryptedKeyForRecipientSha1',
              'editedAt', 'editedBy', 'updatedAt'
            ])
          )
        );
        allow delete: if (isChatParticipant(chatId) &&
          (!('senderId' in resource.data) || resource.data.senderId == request.auth.uid)) || isAdmin();
      }

      // -------- CALLS --------
      match /calls/{callId} {
        allow read: if isSignedIn() && (
          request.auth.uid == resource.data.callerId ||
          request.auth.uid == resource.data.calleeId ||
          isAdmin()
        );

        allow create: if isChatParticipant(chatId) &&
          request.auth.uid == request.resource.data.callerId &&
          request.resource.data.calleeId is string &&
          request.resource.data.calleeId.size() > 0 &&
          request.resource.data.callType in ['voice', 'video'] &&
          request.resource.data.status == 'RINGING' &&
          request.resource.data.startedAt is number;

        allow update: if isChatParticipant(chatId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'updatedAt', 'acceptedAt', 'declinedAt', 'endedAt', 'missedAt',
            'connectedAt', 'offerSdp', 'offerType', 'answerSdp'
          ]) && (
            request.auth.uid == resource.data.callerId ||
            request.auth.uid == resource.data.calleeId ||
            isAdmin()
          );

        allow delete: if isAdmin();

        match /callerCandidates/{candidateId} {
          allow read: if isCallParticipant(chatId, callId) || isAdmin();
          allow create, update, delete: if isCallParticipant(chatId, callId) &&
            request.auth.uid == get(/databases/$(database)/documents/chats/$(chatId)/calls/$(callId)).data.callerId;
        }

        match /calleeCandidates/{candidateId} {
          allow read: if isCallParticipant(chatId, callId) || isAdmin();
          allow create, update, delete: if isCallParticipant(chatId, callId) &&
            request.auth.uid == get(/databases/$(database)/documents/chats/$(chatId)/calls/$(callId)).data.calleeId;
        }
      }
    }

    // ============ PRESENCE ============
    match /presence/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    // ============ PUBLIC KEYS ============
    match /publicKeys/{userId} {
      allow read: if isSignedIn();

      allow create, update: if (isOwner(userId) &&
        hasRequiredFields(['publicKey', 'uploadedAt']) &&
        request.resource.data.publicKey is string &&
        request.resource.data.publicKey.size() > 100) || isAdmin();

      allow delete: if isAdmin();
    }

    // ============ STORIES ============
    match /stories/{storyId} {
      function isFollowerOfOwner() {
        return exists(/databases/$(database)/documents/users/$(resource.data.ownerId)/followers/$(request.auth.uid));
      }

      allow get: if isSignedIn() &&
        resource.data.expiresAt is number && request.time.toMillis() < resource.data.expiresAt &&
        (
          resource.data.privacy == 'public' ||
          request.auth.uid == resource.data.ownerId ||
          (resource.data.privacy == 'friends' && isFollowerOfOwner()) ||
          isAdmin()
        );

      allow list: if isSignedIn();

      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.ownerId &&
        hasRequiredFields(['ownerId', 'note', 'privacy', 'createdAt', 'expiresAt']);

      allow update: if isAdmin();
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());

      match /views/{viewerId} {
        allow read: if isSignedIn() && (request.auth.uid == resource.data.ownerId || isAdmin());
        allow create, update: if isSignedIn() && viewerId == request.auth.uid;
        allow delete: if isAdmin();
      }
    }

    // ============ STORY DRAFTS ============
    match /storyDrafts/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // ============ STORY REPLIES ============
    match /storyReplies/{replyId} {
      allow create: if isSignedIn() &&
        request.resource.data.senderId == request.auth.uid &&
        request.resource.data.storyId is string &&
        request.resource.data.receiverId is string &&
        request.resource.data.storyOwnerId is string &&
        request.resource.data.createdAt is number;

      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.senderId ||
        request.auth.uid == resource.data.receiverId ||
        request.auth.uid == resource.data.storyOwnerId ||
        isAdmin()
      );

      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.senderId || isAdmin());
    }

    // ============ POSTS ============
    match /posts/{postId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn();

      allow update: if isSignedIn() && (
        resource.data.authorId == request.auth.uid ||
        (resource.data.userId == request.auth.uid) ||
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'comments', 'shares', 'likedBy'])
      );

      allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || resource.data.userId == request.auth.uid || isAdmin());

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() &&
          request.resource.data.postId is number &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.text is string &&
          request.resource.data.text.size() > 0;
        allow update: if isSignedIn() && (
          resource.data.userId == request.auth.uid ||
          isAdmin() ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'likesCount', 'updatedAt'])
        );
        allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      }

      match /reports/{reporterId} {
        allow read, write: if isSignedIn() || isAdmin();
      }
    }

    match /post_comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.postId is number &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.text is string &&
        request.resource.data.text.size() > 0;
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'likesCount', 'updatedAt'])
      );
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ============ POST ENGAGEMENTS ==========
    match /post_engagements/{postId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() || isAdmin();
      allow delete: if isAdmin();

      match /members/{userId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isOwner(userId) || isAdmin();
      }
    }

    // ============ EVENTS ============
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.ownerId;
      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // ============ EVENT ENGAGEMENT ==========
    match /event_engagements/{eventId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() || isAdmin();
      allow delete: if isAdmin();

      match /members/{userId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isOwner(userId) || isAdmin();
      }

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() &&
          request.resource.data.authorId == request.auth.uid &&
          hasRequiredFields(['authorId', 'authorName', 'authorEmoji', 'text', 'createdAt']) &&
          request.resource.data.text is string &&
          request.resource.data.text.size() > 0 &&
          request.resource.data.createdAt is number;
        allow update: if isSignedIn() && (
          resource.data.authorId == request.auth.uid ||
          isAdmin() ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'likesCount', 'updatedAt'])
        );
        allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
      }
    }

    // ============ GROUPS ============
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() || isAdmin();
      allow delete: if isAdmin();

      // Members subcollection
      match /members/{memberId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() || isAdmin();
      }

      // Join requests subcollection
      match /joinRequests/{requesterId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() || isAdmin();
      }

      // Posts subcollection
      match /posts/{postId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn() || isAdmin();
        allow delete: if isSignedIn() || isAdmin();

        // Comments subcollection
        match /comments/{commentId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn() &&
            request.resource.data.authorId == request.auth.uid &&
            request.resource.data.content is string &&
            request.resource.data.content.size() > 0;
          allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
        }

        // Post reports subcollection
        match /reports/{reporterId} {
          allow read: if isSignedIn() || isAdmin();
          allow write: if isSignedIn() || isAdmin();
        }
      }
    }

    // ============ FRIENDS (under users) ============
    match /users/{userId}/friends/{friendId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isOwner(userId) || isAdmin();
    }

    // ============ BLOCKED USERS (under users) ============
    match /users/{userId}/blockedUsers/{blockedUserId} {
      allow read, create, update, delete: if isOwner(userId) || isAdmin();
    }

    // ============ COLLECTION GROUPS ============
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/joinRequests/{requesterId} {
      allow read: if isSignedIn();
    }

    // ============ DENY EVERYTHING ELSE ============
    match /{document=**} {
      allow read, write: if false || isAdmin();
    }
  }
}

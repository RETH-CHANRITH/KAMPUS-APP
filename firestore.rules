rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============ HELPER FUNCTIONS ============
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isGroupAdmin(groupId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/groups/$(groupId)).data.adminId == request.auth.uid;
    }

    function hasRequiredFields(requiredFields) {
      return request.resource.data.keys().hasAll(requiredFields);
    }

    function isChatParticipant(chatId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/chats/$(chatId)).data.participants is list &&
        get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
    }

    function isCallParticipant(chatId, callId) {
      return isChatParticipant(chatId) &&
        get(/databases/$(database)/documents/chats/$(chatId)/calls/$(callId)).data.callerId is string &&
        get(/databases/$(database)/documents/chats/$(chatId)/calls/$(callId)).data.calleeId is string &&
        (
          request.auth.uid == get(/databases/$(database)/documents/chats/$(chatId)/calls/$(callId)).data.callerId ||
          request.auth.uid == get(/databases/$(database)/documents/chats/$(chatId)/calls/$(callId)).data.calleeId
        );
    }

    // ============ USERS ============
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && hasRequiredFields(['id', 'displayName', 'email']) && request.resource.data.id == userId;
      allow update: if isOwner(userId) || isAdmin() || (
        isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stats', 'updatedAt', 'isOnline'])
      );
      allow delete: if false;

      match /fcmTokens/{token} {
        allow read, write: if isOwner(userId);
      }

      match /presence/{presenceDoc} {
        allow read, write: if isOwner(userId);
      }

      match /followers/{followerId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.userId == followerId &&
          request.resource.data.createdAt is number;
        allow delete: if isSignedIn() && (request.auth.uid == resource.data.userId || isOwner(userId));
      }

      match /following/{followingId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() &&
          request.auth.uid == userId &&
          request.resource.data.userId == followingId &&
          request.resource.data.createdAt is number;
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /friendRequests/{requestId} {
        allow read: if isOwner(userId);
        allow create: if isSignedIn() &&
          request.resource.data.fromUserId == request.auth.uid &&
          request.resource.data.toUserId == userId &&
          hasRequiredFields(['fromUserId', 'toUserId', 'createdAt']);
        allow delete: if isOwner(userId) || resource.data.fromUserId == request.auth.uid;
      }

      match /outgoingFriendRequests/{requestId} {
        allow read, write: if isOwner(userId);
      }

      match /notifications/{notificationId} {
        allow read: if isOwner(userId);
        allow create: if isSignedIn() &&
          request.resource.data.actorUserId == request.auth.uid &&
          request.resource.data.toUserId == userId &&
          hasRequiredFields(['actorUserId', 'toUserId', 'type', 'createdAt']);
        allow update, delete: if isOwner(userId);
      }

      match /blocks/{blockedUserId} {
        allow read: if isOwner(userId);
        allow create, write: if isOwner(userId) &&
          hasRequiredFields(['blockedAt']) &&
          request.resource.data.blockedAt is number;
        allow delete: if isOwner(userId);
      }

      match /activities/{activityId} {
        allow read: if isSignedIn();
        allow create: if isOwner(userId) && hasRequiredFields(['type', 'text', 'createdAt']);
        allow update, delete: if isOwner(userId);
      }

      match /incomingCalls/{callId} {
        allow read: if isOwner(userId);
        allow create: if isSignedIn() &&
          request.resource.data.callerId is string &&
          request.resource.data.callerId == request.auth.uid &&
          request.resource.data.calleeId is string &&
          request.resource.data.calleeId == userId &&
          request.resource.data.chatId is string &&
          request.resource.data.callId is string &&
          request.resource.data.startedAt is number &&
          request.resource.data.updatedAt is number &&
          request.resource.data.status is string &&
          request.resource.data.status == 'RINGING' &&
          request.resource.data.callType is string &&
          request.resource.data.callType in ['voice', 'video'];
        allow update: if isOwner(userId) || (isSignedIn() && request.auth.uid == resource.data.callerId);
        allow delete: if isOwner(userId) || (isSignedIn() && request.auth.uid == resource.data.callerId);
      }
    }

    // ============ GROUPS ============
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.adminId == request.auth.uid;
      allow update: if isAdmin() || isGroupAdmin(groupId) || (
        isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'memberCount',
          'postCount',
          'updatedAt',
          'lastActivityAt'
        ])
      );
      allow delete: if isAdmin() || isGroupAdmin(groupId);

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow create: if isAdmin() || isGroupAdmin(groupId) || memberId == request.auth.uid;
        allow update: if isAdmin() || isGroupAdmin(groupId) || memberId == request.auth.uid;
        allow delete: if isAdmin() || isGroupAdmin(groupId) || memberId == request.auth.uid;
      }

      match /joinRequests/{requestId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAdmin() || isGroupAdmin(groupId) || requestId == request.auth.uid;
      }

      match /posts/{postId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update: if isAdmin() || isGroupAdmin(groupId) || resource.data.authorId == request.auth.uid || (
          isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'likedBy',
            'likeCount',
            'commentCount',
            'isReported',
            'reportCount'
          ])
        );
        allow delete: if isAdmin() || isGroupAdmin(groupId) || resource.data.authorId == request.auth.uid;

        match /reports/{reportId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn() && request.resource.data.reportedByUserId == request.auth.uid;
          allow update, delete: if isAdmin() || isGroupAdmin(groupId) || reportId == request.auth.uid;
        }
      }
    }

    // ============ CHATS ============
    match /chats/{chatId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if isChatParticipant(chatId);

      match /messages/{messageId} {
        allow read: if isChatParticipant(chatId);
        allow create: if isChatParticipant(chatId) && request.resource.data.senderId == request.auth.uid;
        allow update: if isChatParticipant(chatId);
        allow delete: if isChatParticipant(chatId) && resource.data.senderId == request.auth.uid;
      }

      match /calls/{callId} {
        allow read, write: if isChatParticipant(chatId);
        match /{any=**} { allow read, write: if isChatParticipant(chatId); }
      }
    }

    // ============ POSTS ============
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.authorId;
      allow update: if isSignedIn() && (
        resource.data.authorId == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'comments', 'shares', 'likedBy'])
      );
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;

      match /reports/{reportId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && (
          request.resource.data.reporterId == request.auth.uid ||
          request.resource.data.reportedByUserId == request.auth.uid
        );
        allow update, delete: if isAdmin();
      }
    }

    match /post_comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ============ OTHER PUBLIC COLLECTIONS ============
    match /stories/{storyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.ownerId;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      match /views/{viewerId} { allow write: if isSignedIn() && viewerId == request.auth.uid; }
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && (
        request.resource.data.reporterId == request.auth.uid ||
        request.resource.data.reportedByUserId == request.auth.uid
      );
      allow update, delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() || isAdmin();
    }

    match /presence/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /publicKeys/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // ============ GLOBAL CATCH-ALL ============
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

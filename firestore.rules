rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============ HELPER FUNCTIONS ============
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isGroupAdmin(groupId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/groups/$(groupId)).data.adminId == request.auth.uid;
    }

    function hasRequiredFields(requiredFields) {
      return request.resource.data.keys().hasAll(requiredFields);
    }

    function isChatParticipant(chatId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/chats/$(chatId)).data.participants is list &&
        get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
    }

    function isCallParticipant(chatId, callId) {
      return isChatParticipant(chatId) &&
        get(/databases/$(database)/documents/chats/$(chatId)/calls/$(callId)).data.callerId is string &&
        get(/databases/$(database)/documents/chats/$(chatId)/calls/$(callId)).data.calleeId is string &&
        (
          request.auth.uid == get(/databases/$(database)/documents/chats/$(chatId)/calls/$(callId)).data.callerId ||
          request.auth.uid == get(/databases/$(database)/documents/chats/$(chatId)/calls/$(callId)).data.calleeId
        );
    }

    // ============ USERS ============
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && hasRequiredFields(['id', 'displayName', 'email']) && request.resource.data.id == userId;
      allow update: if isOwner(userId) || isAdmin() || (
        isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stats', 'updatedAt', 'isOnline'])
      );
      allow delete: if false;

      match /fcmTokens/{token} {
        allow read, write: if isOwner(userId);
      }

      match /presence/{presenceDoc} {
        allow read, write: if isOwner(userId);
      }

      match /followers/{followerId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.userId == followerId &&
          request.resource.data.createdAt is number;
        allow delete: if isSignedIn() && (request.auth.uid == resource.data.userId || isOwner(userId));
      }

      match /following/{followingId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() &&
          request.auth.uid == userId &&
          request.resource.data.userId == followingId &&
          request.resource.data.createdAt is number;
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /friendRequests/{requestId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isSignedIn() &&
          request.resource.data.fromUserId == request.auth.uid &&
          request.resource.data.toUserId == userId &&
          hasRequiredFields(['fromUserId', 'toUserId', 'createdAt']);
        allow delete: if isOwner(userId) || resource.data.fromUserId == request.auth.uid;
      }

      match /outgoingFriendRequests/{requestId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /notifications/{notificationId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isSignedIn() &&
          request.resource.data.actorUserId == request.auth.uid &&
          request.resource.data.toUserId == userId &&
          hasRequiredFields(['actorUserId', 'toUserId', 'type', 'createdAt']);
        allow update, delete: if isOwner(userId);
      }

      match /blocks/{blockedUserId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, write: if (isOwner(userId) &&
          hasRequiredFields(['blockedAt']) &&
          request.resource.data.blockedAt is number) || isAdmin();
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /activities/{activityId} {
        allow read: if isSignedIn();
        allow create: if isOwner(userId) && hasRequiredFields(['type', 'text', 'createdAt']);
        allow update, delete: if isOwner(userId);
      }

      match /incomingCalls/{callId} {
        allow read: if isOwner(userId);
        allow create: if isSignedIn() &&
          request.resource.data.callerId is string &&
          request.resource.data.callerId == request.auth.uid &&
          request.resource.data.calleeId is string &&
          request.resource.data.calleeId == userId &&
          request.resource.data.chatId is string &&
          request.resource.data.callId is string &&
          request.resource.data.startedAt is number &&
          request.resource.data.updatedAt is number &&
          request.resource.data.status is string &&
          request.resource.data.status == 'RINGING' &&
          request.resource.data.callType is string &&
          request.resource.data.callType in ['voice', 'video'];
        allow update: if isOwner(userId) || (isSignedIn() && request.auth.uid == resource.data.callerId);
        allow delete: if isOwner(userId) || (isSignedIn() && request.auth.uid == resource.data.callerId);
      }
<<<<<<< HEAD
    }

    // ============ GROUPS ============
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.adminId == request.auth.uid;
      allow update: if isAdmin() || isGroupAdmin(groupId) || (
        isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'memberCount',
          'postCount',
          'updatedAt',
          'lastActivityAt'
        ])
      );
      allow delete: if isAdmin() || isGroupAdmin(groupId);

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow create: if isAdmin() || isGroupAdmin(groupId) || memberId == request.auth.uid;
        allow update: if isAdmin() || isGroupAdmin(groupId) || memberId == request.auth.uid;
        allow delete: if isAdmin() || isGroupAdmin(groupId) || memberId == request.auth.uid;
      }

      match /joinRequests/{requestId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAdmin() || isGroupAdmin(groupId) || requestId == request.auth.uid;
      }

      match /posts/{postId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update: if isAdmin() || isGroupAdmin(groupId) || resource.data.authorId == request.auth.uid || (
          isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'likedBy',
            'likeCount',
            'commentCount',
            'isReported',
            'reportCount'
          ])
        );
        allow delete: if isAdmin() || isGroupAdmin(groupId) || resource.data.authorId == request.auth.uid;

        match /reports/{reportId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn() && request.resource.data.reportedByUserId == request.auth.uid;
          allow update, delete: if isAdmin() || isGroupAdmin(groupId) || reportId == request.auth.uid;
        }
      }
    }

    // ============ GLOBAL REPORTS ============
    // NEW: Needed for Admin Moderation feature
    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    // ============ CHATS ============
    match /chats/{chatId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if isChatParticipant(chatId);

      match /messages/{messageId} {
        allow read: if isChatParticipant(chatId);
        allow create: if isChatParticipant(chatId) && request.resource.data.senderId == request.auth.uid;
        allow update: if isChatParticipant(chatId);
        allow delete: if isChatParticipant(chatId) && resource.data.senderId == request.auth.uid;
      }

      match /calls/{callId} {
        allow read, write: if isChatParticipant(chatId);
        match /{any=**} { allow read, write: if isChatParticipant(chatId); }
      }
    }

    // ============ PRESENCE ============
    match /presence/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // ============ PUBLIC KEYS ============
    match /publicKeys/{userId} {
      allow read: if isSignedIn();

      allow create, update: if isOwner(userId) &&
        hasRequiredFields(['publicKey', 'uploadedAt']) &&
        request.resource.data.publicKey is string &&
        request.resource.data.publicKey.size() > 100;

      allow delete: if false;
    }

    // ============ STORIES ============
    match /stories/{storyId} {
      // Allow read only for signed-in users and only if story is not expired
      // and the privacy rules permit it (public, friends, or owner).
      function isFollowerOfOwner() {
        return exists(/databases/$(database)/documents/users/$(resource.data.ownerId)/followers/$(request.auth.uid));
      }

      allow get: if isSignedIn() &&
        // story must not be expired
        resource.data.expiresAt is number && request.time.toMillis() < resource.data.expiresAt &&
        (
          resource.data.privacy == 'public' ||
          request.auth.uid == resource.data.ownerId ||
          (resource.data.privacy == 'friends' && isFollowerOfOwner())
        );

      // Allow the story feed query to load for signed-in users; the client still
      // filters expired stories and the UI only surfaces story actions to owners.
      allow list: if isSignedIn();

      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.ownerId &&
        hasRequiredFields(['ownerId', 'note', 'privacy', 'createdAt', 'expiresAt']);

      allow update: if false;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      match /views/{viewerId} {
        // Only the story owner may read the viewers list for privacy.
        allow read: if isSignedIn() && request.auth.uid == resource.data.ownerId;
        // A user may create or update their own view record.
        allow create, update: if isSignedIn() && viewerId == request.auth.uid;
        allow delete: if false;
      }
    }

    // ============ STORY DRAFTS ============
    match /storyDrafts/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ============ STORY REPLIES ============
    match /storyReplies/{replyId} {
      allow create: if isSignedIn() &&
        request.resource.data.senderId == request.auth.uid &&
        request.resource.data.storyId is string &&
        request.resource.data.receiverId is string &&
        request.resource.data.storyOwnerId is string &&
        request.resource.data.createdAt is number;

      // Sender, receiver, and story owner may read replies
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.senderId ||
        request.auth.uid == resource.data.receiverId ||
        request.auth.uid == resource.data.storyOwnerId
      );

      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.senderId;
    }

    // ============ POSTS ============
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.authorId;
      allow update: if isSignedIn() && (
        resource.data.authorId == request.auth.uid ||
        (resource.data.userId == request.auth.uid) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'comments', 'shares', 'likedBy'])
      );
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;

      match /reports/{reportId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() &&
          request.resource.data.postId is number &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.text is string &&
          request.resource.data.text.size() > 0;
        allow update: if isSignedIn() && (
          resource.data.userId == request.auth.uid ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'likesCount', 'updatedAt'])
        );
        allow update, delete: if isAdmin();
      }
    }

    match /post_comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ============ OTHER PUBLIC COLLECTIONS ============
    match /stories/{storyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.ownerId;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      match /views/{viewerId} { allow write: if isSignedIn() && viewerId == request.auth.uid; }
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && (
        request.resource.data.reporterId == request.auth.uid ||
        request.resource.data.reportedByUserId == request.auth.uid
      );
      allow update, delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
=======
